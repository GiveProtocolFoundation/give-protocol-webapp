# ============================================
# RPC URLS (Optional - uses server proxy if not set)
# ============================================
# Set these to dedicated RPC providers (Alchemy, Infura) for production.
# In development, requests are proxied through the Express server to avoid CORS.
# VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# VITE_OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# VITE_MOONBEAM_RPC_URL=https://rpc.api.moonbeam.network
# VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_OPTIMISM_SEPOLIA_RPC_URL=https://opt-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_MOONBASE_RPC_URL=https://rpc.api.moonbase.moonbeam.network

# ============================================
# FEATURE FLAGS
# ============================================
VITE_SHOW_TESTNETS=false
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_WEB3=true
# Local-only demo flag: when true, the donor dashboard renders a placeholder
# Skills & Endorsements section. Leave unset (or false) in production.
VITE_SHOW_DEMO_SKILLS=false

# ============================================
# HELCIM PAYMENT GATEWAY (Frontend)
# ============================================
# Test mode for HelcimPay.js (set to false in production)
VITE_HELCIM_TEST_MODE=true
# HelcimPay.js token - NOT currently used; checkout tokens are fetched
# dynamically from the helcim-pay edge function. Reserved for future use.
# VITE_HELCIM_JS_TOKEN=

# ============================================
# PAYPAL (Frontend - Client ID only, safe for browser)
# ============================================
VITE_PAYPAL_CLIENT_ID=

# ============================================
# HELCIM API CREDENTIALS (Supabase Edge Functions)
# ============================================
# These are set in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# DO NOT put these in .env - they are server-side secrets only
#
# HELCIM_API_TOKEN=your-helcim-api-token
# HELCIM_ACCOUNT_ID=your-helcim-account-id
# HELCIM_TERMINAL_ID=your-helcim-terminal-id
# HELCIM_TEST_MODE=true

# ============================================
# PAYPAL API CREDENTIALS (Supabase Edge Functions)
# ============================================
# These are set in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# DO NOT put these in .env - they are server-side secrets only
#
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=sandbox

# ============================================
# TRANSACTIONAL EMAIL (Supabase Edge Functions)
# ============================================
# Required by the charity-status-email edge function (GIV-113).
# Sign up at https://resend.com and add your domain (giveprotocol.io).
# Set in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# DO NOT put these in .env - they are server-side secrets only
#
# RESEND_API_KEY=re_your_resend_api_key

# ============================================
# MONITORING (Optional)
# ============================================
VITE_SENTRY_DSN=
VITE_MONITORING_API_KEY=
VITE_MONITORING_APP_ID=
VITE_MONITORING_ENVIRONMENT=development

# ============================================
# CYPRESS E2E (Test-only — never set in production)
# ============================================
# Service-role key for Supabase Admin API — used by cy.supabaseLogin()
# to create test users and bootstrap PKCE sessions headlessly.
# Set via CYPRESS_ prefix or cypress.env.json.
# CYPRESS_SUPABASE_URL=https://your-project.supabase.co
# CYPRESS_SUPABASE_ANON_KEY=your-anon-key
# CYPRESS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
